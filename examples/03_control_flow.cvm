// 03_control_flow.cvm  —  if/else and while loops
let a = 10;

if (a > 5) {
    print 1;
} else {
    print 0;
}

if (a == 99) {
    print 999;
} else {
    print 111;
}

// While loop: print 1 to 5
let i = 1;
while (i <= 5) {
    print i;
    i = i + 1;
}

// Fibonacci: first 10 numbers
let fib_a = 0;
let fib_b = 1;
let count = 0;
while (count < 10) {
    print fib_a;
    let temp = fib_a + fib_b;
    fib_a = fib_b;
    fib_b = temp;
    count = count + 1;
}
